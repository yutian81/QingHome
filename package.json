{
  "name": "qinghome2",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "QingHome2 - 动态个人主页（D1 + 管理后台）",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
